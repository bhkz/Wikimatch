# OPENAI_API_KEY: primary private Desk AI provider. Server-side only.
# Never prefix with VITE_; never expose in the public bundle.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# GEMINI_API_KEY: private Desk AI fallback provider. Server-side only.
# Never prefix with VITE_; never expose in the public bundle.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AI_DAILY_EUR_CAP: daily cap for all Desk AI providers combined.
# 6.50 EUR/day keeps the monthly AI budget under ~200 EUR.
AI_DAILY_EUR_CAP="6.50"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_DATA_MODE: data layer mode for the public frontend.
# "demo" (default) → fixtures in src/mock*Data.ts via DemoPublicDataProvider.
# "live"           → calls /api/public/v1/* via LivePublicDataProvider (Phase 2+).
# Any other value is treated as "demo".
VITE_DATA_MODE="demo"

# VITE_PUBLIC_API_BASE: public read API base used by LivePublicDataProvider.
# Empty means same-origin, e.g. /api/public/v1 on Vercel.
VITE_PUBLIC_API_BASE=""

# Supabase V2 project credentials.
# SERVICE key is server-side only. ANON key can be public only if needed.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Wikimedia worker (Render / local Phase 3).
WIKIMEDIA_USER_AGENT="WikiMatch/2.0 (contact@example.com) Node"
WORKER_STREAM_NAME="wikimedia-recentchange"
WORKER_DRY_RUN="true"
WORKER_FETCH_DIFF="true"
LOG_LEVEL="info"
